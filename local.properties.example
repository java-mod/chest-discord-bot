# local.properties.example
# 이 파일을 프로젝트 루트에 local.properties 로 복사한 뒤 실제 값을 입력하세요.
# local.properties 는 .gitignore 에 포함되어 있으므로 git 에 커밋되지 않습니다.

# ── Discord 봇 토큰 ───────────────────────────────────────────
discord.token=CHANGE_ME

# ── REST API 어드민 키 (X-Admin-Key 헤더) ─────────────────────
app.admin-key=CHANGE_ME

# ── DB ───────────────────────────────────────────────────────
# local.properties 에서 사용할 DB 프로파일을 선택하세요.
# - H2   : spring.profiles.active=h2
# - MySQL: spring.profiles.active=mysql
spring.profiles.active=h2
# MySQL 연결정보는 빌드 산출물에 포함되지 않습니다.
# MySQL을 쓸 때만 아래 3줄의 주석을 해제하고 값을 채우세요.
# app.datasource.mysql.url=jdbc:mysql://127.0.0.1:3306/chest_bot?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&characterEncoding=UTF-8
# app.datasource.mysql.username=chest_bot
# app.datasource.mysql.password=CHANGE_ME

# ── 레거시 H2 → MySQL 마이그레이션 ────────────────────────────
app.legacy-h2.enabled=false
app.legacy-h2.search-paths=/root/bot/chest_bot/data/chestbot,./data/chestbot
app.legacy-h2.primary-username=sa
app.legacy-h2.primary-password=

# ── JSONL → SQL 로그 마이그레이션 ──────────────────────────────
# 로컬 테스트는 false 권장. 운영에서 기존 로그를 DB로 이관할 때만 true.
app.log-migration.enabled=false
